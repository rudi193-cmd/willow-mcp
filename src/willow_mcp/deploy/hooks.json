{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "{{WILLOW_MCP_PYTHON}} -m willow_mcp.session_start_hook",
        "timeout": 15,
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": "{{WILLOW_MCP_PYTHON}} -m willow_mcp.pre_tool_hook",
        "timeout": 5
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "{{WILLOW_MCP_PYTHON}} -m willow_mcp.pre_tool_hook",
        "timeout": 5
      }
    ]
  }
}
